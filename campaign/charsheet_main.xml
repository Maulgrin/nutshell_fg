      <size width="760" height="760" />
    </placement>
    <script>
      function nsCall(sFunc, ...)
        if _G and _G[sFunc] then
          return _G[sFunc](...)
        end
        if manager_nutshell and manager_nutshell[sFunc] then
          return manager_nutshell[sFunc](...)
        end
        return nil
      end
      function initRecord(...)
        return nsCall("initRecord", ...)
      end
      function updateDerived(...)
        return nsCall("updateDerived", ...)
      end
      function performSkillRoll(...)
        return nsCall("performSkillRoll", ...)
      end
      function performAttackRoll(...)
        return nsCall("performAttackRoll", ...)
      end
      function refreshSkillsSetIndicator()
        local nTotal = 0
        local aSkills = {"closecombat", "rangedcombat", "perception", "survival", "endurance", "fitness", "persuasion", "expertise", "power", "skulduggery", "operate"}
        local node = getDatabaseNode()
        if node then
          for _, sSkill in ipairs(aSkills) do
            nTotal = nTotal + (tonumber(DB.getValue(node, sSkill, 0)) or 0)
          end
        end
        skills_total.setValue(nTotal)
        skills_set.setValue("Skills Set")
        if nTotal == 5 then
          skills_set.setColor("00AA00")
        else
          skills_set.setColor("FF0000")
        end
      end
      function onInit()
        initRecord(getDatabaseNode(), false)
        refreshSkillsSetIndicator()
      end
      function refreshDerived()
        updateDerived(getDatabaseNode())
        refreshSkillsSetIndicator()
      end
    </script>
